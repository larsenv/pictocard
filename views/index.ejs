<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>PictoCard - Send a Greeting Card</title>
</head>
<body>
<%- include('partials/header') %>

<main class="container">

  <% if (success) { %>
  <div class="alert alert-success">
    🎉 Your card was sent successfully!
  </div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-error">
    <%= error %>
  </div>
  <% } %>

  <section class="hero">
    <h1>Send a PictoCard</h1>
    <p class="hero-sub">Create a personalized greeting card and deliver it by email - or straight to a Wii via WiiLink.</p>
    <p class="hero-desc">
      PictoCard is a simple, no-account-needed service for sending custom image and text greeting cards.
      Upload any photo, write your message, pick a font and color, then share it with someone special.
      Inspired by the simplicity of Apple iCards - no bloat, just a card.
    </p>
  </section>

  <form action="/create" method="POST" enctype="multipart/form-data" class="card-form" id="cardForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <!-- ── Recipient (tab switcher) ── -->
    <fieldset class="form-group">
      <legend>Who is this for?</legend>

      <div class="delivery-tabs">
        <button type="button" class="tab-btn tab-active" id="tabEmail" onclick="switchTab('email')">
          ✉️ Send by Email
        </button>
        <button type="button" class="tab-btn" id="tabDiscord" onclick="switchTab('discord')">
          💬 Send via Discord
        </button>
      </div>

      <div id="panelEmail" class="tab-panel">
        <div class="field">
          <label for="recipientEmail">Recipient Email Address</label>
          <input type="email" id="recipientEmail" name="recipientEmail"
                 placeholder="friend@example.com" autocomplete="off" />
        </div>
      </div>

      <div id="panelDiscord" class="tab-panel" style="display:none">
        <div class="field">
          <label for="recipientDiscord">Discord Username</label>
          <input type="text" id="recipientDiscord" name="recipientDiscord"
                 placeholder="discordusername" autocomplete="off" />
          <span class="field-hint">Enter the recipient's Discord username (no @). The PictoCard bot must share a server with them. <a href="http://discord.com/oauth2/authorize?client_id=1480701823382720582&amp;permissions=3072&amp;scope=bot" target="_blank" rel="noopener">Invite the bot</a></span>
        </div>
        <div class="field">
          <label for="discordDisplayName">Your Discord Display Name</label>
          <input type="text" id="discordDisplayName" name="discordDisplayName"
                 placeholder="How you want to appear to the recipient" maxlength="80" autocomplete="off" />
          <span class="field-hint">This name is shown to the recipient when the bot delivers your card.</span>
        </div>
      </div>
    </fieldset>

    <!-- ── Sender ── -->
    <fieldset class="form-group">
      <legend>About you</legend>

      <div class="field" id="senderNameField">
        <label for="senderName">Your Name <span class="required">*</span></label>
        <input type="text" id="senderName" name="senderName" required
               placeholder="Your name" maxlength="80" />
        <span class="field-hint" id="senderNameHint">Shown on the card and in the email.</span>
      </div>

      <div class="field">
        <label for="senderEmail">Your Email <span class="required">*</span>
          <span class="field-hint">(used only to send you a verification code)</span>
        </label>
        <input type="email" id="senderEmail" name="senderEmail" required
               placeholder="you@example.com" autocomplete="off" />
      </div>
    </fieldset>

    <!-- ── Image ── -->
    <fieldset class="form-group">
      <legend>Card Image</legend>

      <div class="field">
        <label for="cardImage">Upload an Image</label>
        <input type="file" id="cardImage" name="cardImage"
               accept="image/jpeg,image/png,image/gif,image/webp" />
        <span class="field-hint">JPEG, PNG, GIF or WebP - max 10 MB</span>
      </div>

      <% if (presets && presets.length > 0) { %>
      <div class="field">
        <label>Or choose a preset</label>
        <div class="preset-gallery">
          <% presets.forEach(function(src) { %>
          <label class="preset-option">
            <input type="radio" name="presetImage" value="<%= src %>" />
            <img src="<%= src %>" alt="Preset" loading="lazy" />
          </label>
          <% }); %>
        </div>
      </div>
      <% } %>
    </fieldset>

    <!-- ── Message ── -->
    <fieldset class="form-group">
      <legend>Your Message</legend>

      <div class="field">
        <label for="cardText">Message <span class="char-counter" id="charCounter">0 / 500</span></label>
        <textarea id="cardText" name="cardText" rows="5" maxlength="500"
                  placeholder="Write your message here..."></textarea>
      </div>

      <div class="field-row">
        <div class="field field-grow">
          <label for="fontFamily">Font</label>
          <select id="fontFamily" name="fontFamily">
            <% fonts.forEach(function(f) { %>
            <option value="<%= f.family %>" data-file="<%= f.file %>"><%= f.name %></option>
            <% }); %>
          </select>
          <div id="fontPreview" class="font-preview" aria-hidden="true">
            <img id="fontPreviewImg" src="" alt="" style="max-width:100%;max-height:56px;display:none;" />
          </div>
        </div>

        <div class="field field-shrink">
          <label for="textColor">Text Color</label>
          <div class="color-picker-wrap">
            <input type="color" id="textColor" name="textColor" value="#111111" />
            <span class="color-label" id="colorLabel">#111111</span>
          </div>
        </div>
      </div>
    </fieldset>

    <!-- ── Optional extras ── -->
    <fieldset class="form-group extras">
      <legend>Optional Extras</legend>

      <div class="field">
        <label for="miiFile">Mii Binary File</label>
        <input type="file" id="miiFile" name="miiFile"
               accept=".ffsd,.miibinary,application/octet-stream" />
        <span class="field-hint">Upload your Mii binary file (.ffsd or .miibinary) to add your Mii face to the bottom-right corner of the card.</span>
      </div>

      <div class="field">
        <label for="miiQrFile">Mii QR Code</label>
        <input type="file" id="miiQrFile" name="miiQrFile"
               accept="image/jpeg,image/png,image/webp,image/gif" />
        <span class="field-hint">Upload an image of a Mii QR code from 3DS, Wii U, Switch, Wii, or DS to add your Mii face to the card.</span>
      </div>
    </fieldset>

    <button type="submit" class="btn btn-primary btn-lg">
      Continue &rarr;
    </button>
  </form>

  <!-- ── WiiLink notice ── -->
  <aside class="wiilink-notice">
    <h3>📡 Send to a Wii via WiiLink</h3>
    <p>
      You can also send PictoCards directly to a Wii! Just add
      <strong>mail@pictocard.net</strong> as a contact on your Wii's Address Book,
      then enter that address as the recipient above.
    </p>
  </aside>

</main>

<%- include('partials/footer') %>

<script>
  // Character counter
  const ta = document.getElementById('cardText');
  const counter = document.getElementById('charCounter');
  if (ta && counter) {
    ta.addEventListener('input', () => {
      counter.textContent = `${ta.value.length} / 500`;
    });
  }

  // Color picker label sync
  const colorInput = document.getElementById('textColor');
  const colorLabel = document.getElementById('colorLabel');
  if (colorInput && colorLabel) {
    colorInput.addEventListener('input', () => {
      colorLabel.textContent = colorInput.value;
    });
  }

  // Tab switcher
  function switchTab(tab) {
    const emailPanel   = document.getElementById('panelEmail');
    const discordPanel = document.getElementById('panelDiscord');
    const tabEmail     = document.getElementById('tabEmail');
    const tabDiscord   = document.getElementById('tabDiscord');
    const senderHint   = document.getElementById('senderNameHint');

    if (tab === 'email') {
      emailPanel.style.display   = '';
      discordPanel.style.display = 'none';
      tabEmail.classList.add('tab-active');
      tabDiscord.classList.remove('tab-active');
      // Clear discord field to prevent accidental submission
      document.getElementById('recipientDiscord').value = '';
      if (senderHint) senderHint.textContent = 'Shown on the card and in the email.';
    } else {
      emailPanel.style.display   = 'none';
      discordPanel.style.display = '';
      tabEmail.classList.remove('tab-active');
      tabDiscord.classList.add('tab-active');
      // Clear email field
      document.getElementById('recipientEmail').value = '';
      if (senderHint) senderHint.textContent = 'Shown on the card.';
    }
  }

  // Font live preview — loads a preview image named the same as the TTF file
  (function () {
    const fontSelect  = document.getElementById('fontFamily');
    const fontPreview = document.getElementById('fontPreview');
    const previewImg  = document.getElementById('fontPreviewImg');
    if (!fontSelect || !previewImg) return;

    // Build a lookup of safe family -> file pairs from server-rendered options
    const knownFonts = {};
    for (const opt of fontSelect.options) {
      const fam  = opt.value;
      const file = opt.dataset.file || '';
      // Only allow safe characters: alphanumeric, space, dash, dot, underscore
      if (/^[\w\- .]+$/.test(fam) && /^[\w\-.]+\.ttf$/i.test(file)) {
        knownFonts[fam] = file;
      }
    }

    function applyFontPreview() {
      const family = fontSelect.value;
      const file   = knownFonts[family];
      if (!family || !file) {
        previewImg.style.display = 'none';
        return;
      }
      // Derive image path: same basename as TTF, with .png extension
      const imgFile = file.replace(/\.ttf$/i, '.png');
      previewImg.src = `/fonts/${imgFile}`;
      previewImg.alt = family;
      previewImg.style.display = 'block';
    }

    // Hide the preview box if the image fails to load (file not yet added)
    previewImg.addEventListener('error', () => { previewImg.style.display = 'none'; });
    previewImg.addEventListener('load',  () => { previewImg.style.display = 'block'; });

    fontSelect.addEventListener('change', applyFontPreview);
    applyFontPreview(); // set initial preview
  }());
</script>
</body>
</html>
